using FinalProject.Data;
using FinalProject.Models;
using Microsoft.AspNetCore.Mvc;
using Microsoft.EntityFrameworkCore;
using System;

namespace FinalProject.Controllers
{
    [ApiController]
    [Route("api/[controller]")]
    public class MenuController : ControllerBase
    {
        private readonly DefultContext _context;

        public MenuController(DefultContext context)
        {
            _context = context;
        }

        // READ
        [HttpGet("{id?}")]
        public async Task<IActionResult> Get(int? id)
        {
            if (id == null || id == 0)
                return Ok(await _context.MenuItems.Take(5).ToListAsync());

            var item = await _context.MenuItems.FindAsync(id);

            if (item == null)
                return NotFound();

            return Ok(item);
        }

        // CREATE
        [HttpPost]
        public async Task<IActionResult> Create(Menu item)
        {
            if (item.FoodId != 0)
                return BadRequest("Id must not be provided. It is generated by the database.");
            _context.MenuItems.Add(item);
            await _context.SaveChangesAsync();

            return CreatedAtAction(nameof(Get), new { id = item.FoodId }, item);
        }

        // UPDATE
        [HttpPut("{id}")]
        public async Task<IActionResult> Update(int id, Menu item)
        {
            if (id != item.FoodId)
                return BadRequest();

            _context.Entry(item).State = EntityState.Modified;
            await _context.SaveChangesAsync();

            return Ok(item);
        }

        // DELETE
        [HttpDelete("{id}")]
        public async Task<IActionResult> Delete(int id)
        {
            var item = await _context.MenuItems.FindAsync(id);

            if (item == null)
                return NotFound();

            _context.MenuItems.Remove(item);
            await _context.SaveChangesAsync();

            return Ok();
        }
    }
}
